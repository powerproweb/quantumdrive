# <<<|||\\---*** QuantumDrive | https://quantumdrive.io/ ***---///|||>>>
# Last updated: 2026-04-14
# Backup of previous version: .htaccess.bak-2026-04-14
#
# SEARCH & REPLACE BEFORE USE:
#   quantumdrive.io  â†’  e.g. rarefolio.io
#   QuantumDrive    â†’  e.g. Rarefolio
#
# ===========================================================================
# 1. CUSTOM ERROR PAGES
# ===========================================================================
ErrorDocument 400 /404.html
ErrorDocument 401 /404.html
ErrorDocument 403 /404.html
ErrorDocument 404 /404.html
ErrorDocument 500 /404.html

# ===========================================================================
# 2. REWRITES â€” HTTPS + NON-WWW CANONICALIZATION
#    All traffic â†’ https://quantumdrive.io (matches canonical URLs)
# ===========================================================================
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Pass HTTP Basic Auth credentials through to PHP (required on cPanel hosts)
  RewriteCond %{HTTP:Authorization} ^(.*)
  RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Force non-www  (www â†’ non-www)
  RewriteCond %{HTTP_HOST} ^www\.quantumdrive.io$ [NC]
  RewriteRule ^(.*)$ https://quantumdrive.io/$1 [L,R=301]

  # Strip .html from URLs (clean URLs)
  RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # Internally serve the .html file for the clean URL
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L]

  # Optional: Strip .php from URLs (uncomment if needed)
  # RewriteCond %{THE_REQUEST} \s/+(.+)\.php[\s?] [NC]
  # RewriteRule ^ /%1 [R=301,L]
  # RewriteCond %{REQUEST_FILENAME} !-f
  # RewriteCond %{REQUEST_FILENAME} !-d
  # RewriteCond %{REQUEST_FILENAME}.php -f
  # RewriteRule ^(.+)$ $1.php [L]
</IfModule>

# ===========================================================================
# 3. SECURITY HEADERS
# ===========================================================================
<IfModule mod_headers.c>
  # Prevent MIME-type sniffing
  Header set X-Content-Type-Options "nosniff"

  # Prevent clickjacking (site cannot be embedded in iframes on other domains)
  Header set X-Frame-Options "SAMEORIGIN"

  # Control referrer info sent to other sites
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions Policy â€” disable features the site doesn't use
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

  # HSTS â€” tell browsers to always use HTTPS (1 year)
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

  # XSS Protection (legacy browsers)
  Header set X-XSS-Protection "1; mode=block"

  # Content-Security-Policy â€” tighten as needed per project
  # Header set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:;"
</IfModule>

# ===========================================================================
# 4. BROWSER CACHING (Expires)
#    Static assets get long cache lifetimes; HTML stays fresh.
# ===========================================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML â€” short cache so content updates are seen quickly
  ExpiresByType text/html                  "access plus 1 hour"

  # CSS & JS â€” 1 month (cache-bust by renaming or query string on deploy)
  ExpiresByType text/css                   "access plus 1 month"
  ExpiresByType application/javascript     "access plus 1 month"
  ExpiresByType text/javascript            "access plus 1 month"

  # Images â€” 1 year (these rarely change)
  ExpiresByType image/jpeg                 "access plus 1 year"
  ExpiresByType image/png                  "access plus 1 year"
  ExpiresByType image/gif                  "access plus 1 year"
  ExpiresByType image/webp                 "access plus 1 year"
  ExpiresByType image/svg+xml              "access plus 1 year"
  ExpiresByType image/x-icon               "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon   "access plus 1 year"

  # Fonts â€” 1 year
  ExpiresByType font/woff                  "access plus 1 year"
  ExpiresByType font/woff2                 "access plus 1 year"
  ExpiresByType application/font-woff      "access plus 1 year"
  ExpiresByType application/font-woff2     "access plus 1 year"

  # PDFs â€” 1 month
  ExpiresByType application/pdf            "access plus 1 month"

  # Manifest & JSON
  ExpiresByType application/manifest+json  "access plus 1 week"
  ExpiresByType application/json           "access plus 1 hour"

  # XML (sitemap, RSS)
  ExpiresByType application/xml            "access plus 1 hour"
  ExpiresByType text/xml                   "access plus 1 hour"
</IfModule>

# ===========================================================================
# 5. GZIP / DEFLATE COMPRESSION
#    Reduces transfer size for text-based assets (~60-70% smaller).
# ===========================================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/manifest+json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE font/woff
  AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# ===========================================================================
# 6. CORRECT MIME TYPES
#    Ensures browsers interpret files correctly.
# ===========================================================================
<IfModule mod_mime.c>
  AddType image/webp                 .webp
  AddType image/svg+xml              .svg .svgz
  AddType application/manifest+json  .webmanifest
  AddType application/json           .json
  AddType application/pdf            .pdf
  AddType font/woff                  .woff
  AddType font/woff2                 .woff2
  AddType text/javascript            .mjs
</IfModule>

# ===========================================================================
# 7. ETAG CONFIGURATION
#    Use file modification time + size only (reliable across load-balanced servers).
# ===========================================================================
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag MTime Size

# ===========================================================================
# 8. BLOCK ACCESS TO SENSITIVE FILES
#    Prevent direct access to dotfiles, backups, and config.
# ===========================================================================

# Block all dotfiles except .well-known (used by SSL cert renewals)
<IfModule mod_rewrite.c>
  RewriteRule ^(\.(?!well-known)) - [F,L]
</IfModule>

# Block backup and config files
<FilesMatch "\.(bak|old1|old2|config|dist|inc|ini|log|sh|sql|swp|env)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

# Block access to hidden version control directories
<IfModule mod_rewrite.c>
  RewriteRule ^(\.|git|svn|hg) - [F,L]
</IfModule>

# ===========================================================================
# 9. PREVENT DIRECTORY LISTING
# ===========================================================================
Options -Indexes

# ===========================================================================
# 10. IMAGE HOTLINK PROTECTION (optional â€” uncomment to enable)
#     Blocks other sites from embedding your images and stealing bandwidth.
# ===========================================================================
# <IfModule mod_rewrite.c>
#   RewriteCond %{HTTP_REFERER} !^$
#   RewriteCond %{HTTP_REFERER} !^https?://(www\.)?quantumdrive.io/ [NC]
#   RewriteCond %{HTTP_REFERER} !^https?://(www\.)?google\. [NC]
#   RewriteCond %{HTTP_REFERER} !^https?://(www\.)?bing\. [NC]
#   RewriteRule \.(jpg|jpeg|png|gif|webp|svg)$ - [F,NC]
# </IfModule>

# ===========================================================================
# 11. PHP HANDLER (cPanel / BlueHost â€” adjust version as needed)
# ===========================================================================
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>

# <<<|||\\---*** End â€” QuantumDrive .htaccess ***---///|||>>>

