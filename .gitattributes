# ===========================================================================
# .gitattributes
# Auto-detect text files and normalise line endings to LF on commit.
# ===========================================================================

# Default: auto-detect and normalise
* text=auto

# -----------------------------------------------------------------------
# WEB FILES — force LF
# -----------------------------------------------------------------------
*.html         text eol=lf
*.htm          text eol=lf
*.php          text eol=lf
*.css          text eol=lf
*.scss         text eol=lf
*.sass         text eol=lf
*.less         text eol=lf
*.js           text eol=lf
*.mjs          text eol=lf
*.cjs          text eol=lf
*.ts           text eol=lf
*.tsx          text eol=lf
*.jsx          text eol=lf
*.json         text eol=lf
*.jsonc        text eol=lf
*.md           text eol=lf
*.markdown     text eol=lf
*.xml          text eol=lf
*.svg          text eol=lf
*.yaml         text eol=lf
*.yml          text eol=lf
*.toml         text eol=lf
*.ini          text eol=lf
*.env          text eol=lf
*.env.example  text eol=lf
*.txt          text eol=lf
*.csv          text eol=lf
*.sql          text eol=lf
*.sh           text eol=lf
*.bash         text eol=lf
*.conf         text eol=lf
*.htaccess     text eol=lf

# -----------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------
*.py           text eol=lf
*.pyw          text eol=lf
*.pyi          text eol=lf

# -----------------------------------------------------------------------
# CONFIG / DOTFILES
# -----------------------------------------------------------------------
.gitignore     text eol=lf
.gitattributes text eol=lf
Makefile       text eol=lf
Dockerfile     text eol=lf
*.dockerfile   text eol=lf

# -----------------------------------------------------------------------
# BINARY FILES — never diff or convert
# -----------------------------------------------------------------------
# Images
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.webp         binary
*.ico          binary
*.bmp          binary
*.tiff         binary
*.tif          binary
*.psd          binary
*.ai           binary
*.eps          binary

# Fonts
*.woff         binary
*.woff2        binary
*.eot          binary
*.ttf          binary
*.otf          binary

# Documents / Archives
*.pdf          binary
*.zip          binary
*.gz           binary
*.tar          binary
*.rar          binary
*.7z           binary
*.dmg          binary
*.exe          binary
*.dll          binary

# Video / Audio
*.mp4          binary
*.mp3          binary
*.wav          binary
*.ogg          binary
*.webm         binary
*.mov          binary
*.avi          binary
